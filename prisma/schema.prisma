generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Propiedad {
  id           String   @id @default(cuid())
  titulo       String
  descripcion  String
  tipo         String
  operacion    String
  precio       Float
  moneda       String
  comuna       String
  habitaciones Int
  banos        Int
  superficie   Float
  imagenes     String[] 
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}